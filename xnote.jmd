interface BODY {
    name: string
    id: number
    list: any[]
}


binProjectUpdateBranch : async ({isServer, body}: {isServer?: boolean, body?: {name: string}) => {
    return fetch(`${isServer && app_config.host || ''}/api/bin/project/update-branch/`, { method: 'POST', body: JSON.stringify(body), cache: 'no-cache' })
        .then(res => res.json());
}